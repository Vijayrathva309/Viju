<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>₹10000 Balance</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.card {
    width: 320px;
    background: #111;
    color: #fff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.title {
    font-size: 18px;
    opacity: 0.7;
}

.amount {
    font-size: 40px;
    font-weight: bold;
    margin: 15px 0;
    color: #00ffcc;
}

.button {
    display: block;
    width: 100%;
    padding: 12px;
    margin-top: 15px;
    border: none;
    border-radius: 10px;
    background: #00ffcc;
    color: #000;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

.button:hover {
    background: #00ccaa;
}

.footer {
    margin-top: 15px;
    font-size: 12px;
    opacity: 0.6;
    text-align: center;
}
</style>

</head>

<body>

<div class="card">
    <div class="title">Available Balance</div>
    <div class="amount">₹10,000</div>

    <button class="button">Send Money</button>
    <button class="button">Recharge</button>

    <div class="footer">Secure Digital Wallet</div>
</div>

</body>
</html>
